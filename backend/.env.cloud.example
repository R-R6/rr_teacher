# ── 云托管环境变量 ──
# 复制此文件为 .env.cloud，填入真实值后在云托管控制台配置

# 数据库（腾讯云 MySQL）
DB_TYPE=mysql
DB_HOST=你的MySQL内网地址
DB_PORT=3306
DB_USER=你的MySQL用户名
DB_PASSWORD=你的MySQL密码
DB_NAME=chem_teacher

# JWT（生成新的随机密钥）
JWT_SECRET_KEY=在这里生成一个随机密钥

# 安全配置（生产环境）
DEBUG=false
SWAGGER_ENABLED=false
CORS_ORIGINS=你的小程序域名
RATE_LIMIT_PER_MINUTE=120
LOGIN_RATE_LIMIT=5

# OCR 服务（如果本地部署了 OCR 服务，填内网地址）
OCR_SERVICE_URL=http://你的OCR服务地址:8001

# 文件上传
UPLOAD_DIR=./uploads
EXPORT_DIR=./exports
