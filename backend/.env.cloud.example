# 云托管环境变量示例
# 复制为 .env.cloud 后填入真实值，再同步到云托管服务环境变量

DB_TYPE=mysql
DB_HOST=你的MySQL内网地址
DB_PORT=3306
DB_USER=你的MySQL用户名
DB_PASSWORD=你的MySQL密码
DB_NAME=chem_teacher

SECRET_KEY=在这里生成一个32位以上随机密钥
JWT_SECRET_KEY=在这里生成一个32位以上随机密钥

DEBUG=false
SWAGGER_ENABLED=false
# 生产环境不能使用 *，按实际调用来源填写；小程序调用可填微信服务域名或后端允许的业务域名。
CORS_ORIGINS=https://servicewechat.com
RATE_LIMIT_PER_MINUTE=120
LOGIN_RATE_LIMIT=5

OCR_SERVICE_URL=http://你的OCR服务地址:8001
OCR_DEFAULT_ENGINE=tesseract
PIX2TEXT_API_TOKEN=
PIX2TEXT_API_URL=https://api.breezedeus.com/api/pix2text
DOUBAO_API_KEY=
DOUBAO_BASE_URL=
DOUBAO_MODEL=
DOUBAO_TIMEOUT=60
DOUBAO_PROMPT_VERSION=v1

COS_SECRET_ID=
COS_SECRET_KEY=
COS_REGION=ap-guangzhou
COS_BUCKET=

UPLOAD_DIR=./uploads
EXPORT_DIR=./exports
