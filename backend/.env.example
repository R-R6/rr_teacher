# ── 应用基础 ──
APP_NAME=高中化学教学辅助系统
DEBUG=true
# 仅本地开发可使用默认值；生产环境必须改成 32 位以上随机字符串
SECRET_KEY=dev-only-change-me-secret-key

# ── 数据库 (默认SQLite) ──
DB_TYPE=sqlite
DB_HOST=127.0.0.1
DB_PORT=3306
DB_USER=root
DB_PASSWORD=your_mysql_password
DB_NAME=chem_teacher
# Local development may create missing tables automatically. Production must use Alembic migrations.
AUTO_CREATE_TABLES=true

# ── Redis ──
REDIS_URL=redis://127.0.0.1:6379/0

# ── JWT ──
# 仅本地开发可使用默认值；生产环境必须改成 32 位以上随机字符串
JWT_SECRET_KEY=dev-only-change-me-jwt-secret-key
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=1440
JWT_REFRESH_TOKEN_EXPIRE_MINUTES=10080

# ── 腾讯云 COS (图片存储) ──
COS_SECRET_ID=
COS_SECRET_KEY=
COS_REGION=ap-guangzhou
COS_BUCKET=

# ── OCR 服务 ──
OCR_SERVICE_URL=http://127.0.0.1:8001
OCR_TIMEOUT=30

# ── OCR 引擎选择 ──
# 可选: tesseract | pix2text_online | doubao_vision | pix2text_local
#  tesseract       本地 OCR，依赖 tesseract-ocr 系统包 + chi_sim 语言包（云端不卡 AVX2）
#  pix2text_online 调 Pix2Text 在线 API（https://p2t.breezedeus.com），需先注册拿 token
#  doubao_vision   调豆包视觉模型，适合复杂混排题，需配置 DOUBAO_*
#  pix2text_local  本地 Pix2Text（pip install pix2text，仅本地开发）
OCR_DEFAULT_ENGINE=tesseract
OCR_PAID_ENGINES=doubao_vision,pix2text_online
OCR_DAILY_USER_LIMIT=20
OCR_DAILY_GLOBAL_LIMIT=200
PIX2TEXT_API_TOKEN=
PIX2TEXT_API_URL=
DOUBAO_API_KEY=
DOUBAO_BASE_URL=
DOUBAO_MODEL=
DOUBAO_TIMEOUT=60

# ── 文件上传 ──
UPLOAD_DIR=./uploads
MAX_UPLOAD_SIZE_MB=20
EXPORT_DIR=./exports

# ── 安全配置 ──

# API文档开关 (生产环境改为 false)
SWAGGER_ENABLED=true

# 允许的前端来源域名 (逗号分隔, 生产环境务必指定具体域名，不能为 *)
CORS_ORIGINS=http://localhost:3000,http://127.0.0.1:3000,http://localhost:5173,http://127.0.0.1:5173

# 全局速率限制: 每分钟每IP最多请求次数 (0=不限制, 生产环境建议 120)
RATE_LIMIT_PER_MINUTE=0

# 登录速率限制: 每分钟每IP最多登录尝试次数 (防止暴力破解)
LOGIN_RATE_LIMIT=10
