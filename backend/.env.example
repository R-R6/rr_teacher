# ── 应用基础 ──
APP_NAME=高中化学教学辅助系统
DEBUG=true
SECRET_KEY=dfNFId-uJuaPoUozLNVEMn11Ht5cvt3zecY7_BgthG1Ylw-GWxqSxLnxslBLdFbR

# ── 数据库 (默认SQLite) ──
DB_TYPE=sqlite
DB_HOST=127.0.0.1
DB_PORT=3306
DB_USER=root
DB_PASSWORD=your_mysql_password
DB_NAME=chem_teacher

# ── Redis ──
REDIS_URL=redis://127.0.0.1:6379/0

# ── JWT ──
JWT_SECRET_KEY=_8jmWF5Rf4NPOCXrBCSSNm1IZrx-z6VIEkPci9bMqMYr4Rv6ESKaI5pBVtrHxx2f
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=1440
JWT_REFRESH_TOKEN_EXPIRE_MINUTES=10080

# ── 腾讯云 COS (图片存储) ──
COS_SECRET_ID=
COS_SECRET_KEY=
COS_REGION=ap-guangzhou
COS_BUCKET=

# ── OCR 服务 ──
OCR_SERVICE_URL=http://127.0.0.1:8001
OCR_TIMEOUT=30

# ── 文件上传 ──
UPLOAD_DIR=./uploads
MAX_UPLOAD_SIZE_MB=20
EXPORT_DIR=./exports

# ── 安全配置 ──

# API文档开关 (生产环境改为 false)
SWAGGER_ENABLED=true

# 允许的前端来源域名 (逗号分隔, 生产环境务必指定具体域名)
CORS_ORIGINS=http://localhost:3000,http://127.0.0.1:3000,http://localhost:5173,http://127.0.0.1:5173

# 全局速率限制: 每分钟每IP最多请求次数 (0=不限制, 生产环境建议 120)
RATE_LIMIT_PER_MINUTE=0

# 登录速率限制: 每分钟每IP最多登录尝试次数 (防止暴力破解)
LOGIN_RATE_LIMIT=10
